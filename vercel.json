{
  "version": 2,
  "headers": [
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/suggest", "destination": "/api/suggest.js" },
    { "source": "/app", "destination": "/app.html" },
    { "source": "/", "destination": "/index.html" }
  ]
}
